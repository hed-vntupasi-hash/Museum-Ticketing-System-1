<Window x:Class="SimpleAuthSystem.PurchaseTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purchase Museum Ticket" Height="420" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <TextBlock Text="Purchase Museum Ticket"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <!-- User Icon -->
            <Image Source="/Images/user_icon.png"
                   Width="35"
                   Height="35"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"/>
        </Grid>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="0,20,0,0">

            <!-- Ticket Type -->
            <TextBlock Text="Ticket Type"/>
            <ComboBox x:Name="TicketTypeComboBox"
                      Height="30"
                      Margin="0,5,0,15"/>

            <!-- Event Selection -->
            <TextBlock Text="Select Event"/>
            <ComboBox x:Name="EventComboBox"
                      SelectionChanged="EventComboBoxChanged"
                      Height="30"
                      Margin="0,5,0,15"/>


            <StackPanel Orientation="Horizontal" Margin="10">

                <!-- Start Date -->
                <StackPanel Margin="5">
                    <TextBlock Text="Event Start" Margin="0,0,0,3"/>
                    <TextBox x:Name="StartDate"
                             
                             Width="150"
                 IsReadOnly="True"
                 AcceptsReturn="False"
                 TextWrapping="NoWrap"
                 Height="25"
                 VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- End Date -->
                <StackPanel Margin="5">
                    <TextBlock Text="Event Date" Margin="0,0,0,3"/>
                    <TextBox  x:Name="EndDate"
                              Width="150"
                 IsReadOnly="True"
                 AcceptsReturn="False"
                 TextWrapping="NoWrap"
                 Height="25"
                 VerticalContentAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Purchase Ticket"
                    Width="140"
                    Height="35"
                    Margin="10"
                    Background="#4CAF50"
                    Foreground="White" Click="PurchaseTicket_Click"/>

            <Button Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="10"
                    Background="#D32F2F"
                    Foreground="White" Click="Button_Click"/>

        </StackPanel>

    </Grid>
</Window>