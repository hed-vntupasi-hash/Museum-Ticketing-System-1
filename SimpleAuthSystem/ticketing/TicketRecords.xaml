<Page x:Class="SimpleAuthSystem.Pages.TicketRecordsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F9">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Ticket Records"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#1E293B"
                   Margin="0 0 0 20"/>

        <!-- MAIN CONTENT -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20">

            <StackPanel>

                <TextBlock Text="Ticket Records Module"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0 0 0 10"/>

                <TextBlock Text="This page will display ticket history, logs, and records."
                           FontSize="16"
                           Foreground="Gray"
                           Margin="0 0 0 20"/>
                
                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0 0 0 10">

                                <Button Content="Reload"
                        Width="100"
                        Height="35"
                        Click="ReloadButton_Click"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"/>

                </StackPanel>
                
                <DataGrid x:Name="dgTicketRecords"
          AutoGenerateColumns="False"
          Height="350"
          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                            Binding="{Binding ID}"
                            Width="80"/>

                        <DataGridTextColumn Header="Type"
                            Binding="{Binding Type}"
                            Width="120"/>

                        <DataGridTextColumn Header="Event"
                            Binding="{Binding Event}"
                            Width="*"/>

                        <DataGridTextColumn Header="Price"
                            Binding="{Binding Price}"
                            Width="100"/>

                        <DataGridTextColumn Header="Creation Date"
                            Binding="{Binding CreationDate}"
                            Width="180"/>

                        <DataGridTextColumn Header="QR"
                            Binding="{Binding QR}"
                            Width="150"/>

                        <DataGridTextColumn Header="Description"
                            Binding="{Binding Description}"
                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>

        </Border>

        <!-- FOOTER -->

        <Button Grid.Row="2"
                Content="← Back to Dashboard"
                Width="170"
                Height="40"
                Margin="0 20 0 0"
                HorizontalAlignment="Left"
                Click="BackButton_Click"
                Background="#334155"
                Foreground="White"
                BorderThickness="0"/>

    </Grid>

</Page>