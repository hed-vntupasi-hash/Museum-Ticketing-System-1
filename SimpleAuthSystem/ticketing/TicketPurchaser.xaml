<Window x:Class="SimpleAuthSystem.ticketing.TicketPurchaser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket Purchaser"
        Background="#9FAFC1"
        Width="520"
        Height="520">

    <Grid>

        <Border
            Width="480"
            Height="460"
            Background="#8FA0B5"
            BorderBrush="#1A1F4A"
            BorderThickness="8"
            CornerRadius="4"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="12">

            <Border
                Background="#B8C4D6"
                BorderBrush="#3B3F73"
                BorderThickness="4"
                Padding="15">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Text="PURCHASE TICKET"
                               FontSize="20"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               Foreground="#3B3F73"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Form -->
                    <StackPanel Grid.Row="1" Margin="10">

                        <TextBlock Text="Ticket Type"
                                   FontFamily="Consolas"
                                   Foreground="#3B3F73"/>
                        <ComboBox x:Name="TicketTypeComboBox"
                                  Height="28"
                                  Margin="0,5,0,10"/>

                        <TextBlock Text="Select Event"
                                   FontFamily="Consolas"
                                   Foreground="#3B3F73"/>
                        <ComboBox x:Name="EventComboBox"
                                  SelectionChanged="EventComboBoxChanged"
                                  Height="28"
                                  Margin="0,5,0,10"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <StackPanel Margin="5">
                                <TextBlock Text="Start"
                                           FontFamily="Consolas"
                                           Foreground="#3B3F73"/>
                                <TextBox x:Name="StartDate"
                                         Width="150"
                                         Height="25"
                                         IsReadOnly="True"
                                         TextAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Margin="5">
                                <TextBlock Text="End"
                                           FontFamily="Consolas"
                                           Foreground="#3B3F73"/>
                                <TextBox x:Name="EndDate"
                                         Width="150"
                                         Height="25"
                                         IsReadOnly="True"
                                         TextAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>

                        <!-- QR Preview -->
                        <TextBlock Text="Ticket QR"
                                   Margin="0,15,0,5"
                                   FontFamily="Consolas"
                                   Foreground="#3B3F73"
                                   HorizontalAlignment="Center"/>

                        <Image Source="{Binding QrCodeImage}"
                               Width="140"
                               Height="140"
                               HorizontalAlignment="Center"/>

                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button Content="PURCHASE"
                                Width="140"
                                Height="35"
                                Margin="10"
                                Background="#4CAF50"
                                Foreground="White"
                                FontFamily="Consolas"
                                Click="PurchaseTicket_Click"/>

                        <Button Content="CANCEL"
                                Width="120"
                                Height="35"
                                Margin="10"
                                Background="#D32F2F"
                                Foreground="White"
                                FontFamily="Consolas"
                                Click="Button_Click"/>

                    </StackPanel>

                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>