<Window x:Class="SimpleAuthSystem.TicketListing"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product List" Height="400" Width="500" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Inventory Table" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgTickets" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="Event" Binding="{Binding event}" Width="*"/>
                <DataGridTextColumn Header="Ticket Type" Binding="{Binding type}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding price, StringFormat=C}" Width="100"/>

            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Back to Dashboard" Grid.Row="2" Click="btnBack_Click" 
                Width="150" Height="30" HorizontalAlignment="Left" Margin="0,15,0,0"/>
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,15,0,0">
            <Button x:Name="btnBack" Content="Back to Dashboard" 
            Click="btnBack_Click" Width="130" Height="30" Margin="0,0,10,0"/>

            <Button x:Name="btnReload" Content="Reload Data" 
            Click="btnReload_Click" Width="100" Height="30" 
            Background="#007ACC" Foreground="White"/>
        </StackPanel>
    </Grid>
    
</Window>