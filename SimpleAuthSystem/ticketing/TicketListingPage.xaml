<Page x:Class="SimpleAuthSystem.TicketListingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Product List"
      Background="#F4F6F9">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Inventory Table"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#1E293B"
                   Margin="0,0,0,20"/>

        <!-- DataGrid -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="10">

            <DataGrid x:Name="dgTickets"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      RowHeight="35"
                      HeadersVisibility="Column">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding id}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Event"
                                        Binding="{Binding event}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Ticket Type"
                                        Binding="{Binding type}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding price, StringFormat=C}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="2"
                    Margin="0,20,0,0">

            <Button x:Name="btnBack"
                    Content="Back to Dashboard"
                    Click="btnBack_Click"
                    Width="150"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#334155"
                    Foreground="White"
                    BorderThickness="0"/>

            <Button x:Name="btnReload"
                    Content="Reload Data"
                    Click="btnReload_Click"
                    Width="120"
                    Height="35"
                    Background="#2563EB"
                    Foreground="White"
                    BorderThickness="0"/>

        </StackPanel>

    </Grid>

</Page>