
<Window x:Class="SimpleAuthSystem.PurchaseTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purchase Museum Ticket" Height="420" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Purchase Museum Ticket"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top" >

            <!-- Ticket Type -->
            <TextBlock Text="Ticket Type"/>
            <ComboBox Name="TicketTypeComboBox"
                      Height="30"
                      Margin="0,5,0,15"/>

            <!-- Visitor -->
            <TextBlock Text="Visitor"/>
            <ComboBox Name="VisitorComboBox"
                      Height="30"
                      Margin="0,5,0,15"/>

            <!-- Visit Date -->
            <TextBlock Text="Visit Date"/>
            <DatePicker Name="VisitDatePicker"
                        Height="30"
                        Margin="0,5,0,15"/>

            <!-- Status -->
            <TextBlock Text="Status"/>
            <ComboBox Name="StatusComboBox"
                      Height="30"
                      Margin="0,5,0,15">
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Used"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Content="Purchase Ticket"
                    Width="140"
                    Height="35"
                    Margin="10"
                    Background="#4CAF50"
                    Foreground="White"/>

            <Button Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="10"
                    Background="#D32F2F"
                    Foreground="White"/>

        </StackPanel>

    </Grid>
</Window>
