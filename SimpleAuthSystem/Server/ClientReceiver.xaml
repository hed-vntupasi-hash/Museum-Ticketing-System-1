<Window x:Class="SimpleAuthSystem.ClientReceiver"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleAuthSystem"
        mc:Ignorable="d"
Title="SignalR Server" Height="300" Width="400">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock x:Name="StatusLabel" Text="Status: Starting..." FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Incoming Requests:"/>
            <ListBox x:Name="RequestList" Height="180" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Window>