<Page x:Class="SimpleAuthSystem.Pages.ClientReceiverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F9">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Client Receiver"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#1E293B"
                   Margin="0 0 0 20"/>

        <!-- MAIN CARD -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20">

            <StackPanel>

                <!-- Status -->

                <Border Background="#E0F2FE"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0 0 0 15">

                    <TextBlock x:Name="StatusLabel"
                               Text="Status: Starting..."
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="#0369A1"/>
                </Border>

                <!-- Incoming Requests -->

                <TextBlock Text="Incoming Requests"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0 0 0 10"/>

                <ListBox x:Name="RequestList"
                         Height="350"
                         BorderThickness="1"
                         BorderBrush="#D1D5DB"
                         Padding="5"/>

            </StackPanel>

        </Border>

        <!-- FOOTER BUTTON -->

        <Button Grid.Row="2"
                Content="← Back to Dashboard"
                Width="170"
                Height="40"
                HorizontalAlignment="Left"
                Margin="0 20 0 0"
                Click="BackButton_Click"
                Background="#334155"
                Foreground="White"
                BorderThickness="0"/>

    </Grid>

</Page>