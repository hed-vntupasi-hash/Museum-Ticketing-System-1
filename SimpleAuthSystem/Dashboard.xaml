<Window x:Class="SimpleAuthSystem.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SimpleAuthSystem"
        Title="Dashboard"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Grid>

        <!-- MAIN LAYOUT -->
        <Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>

            <!-- Main Content -->
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- ===================================== -->
        <!-- SIDEBAR -->
        <!-- ===================================== -->

        <Border Grid.Column="0"
                Background="#1E293B">

            <StackPanel Margin="15">

                <!-- Logo -->

                <TextBlock Text="SimpleAuth"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="10 20"
                           HorizontalAlignment="Center"/>

                <!-- Buttons -->

             

                <Button Content="📋 Ticket Listing"
                        Height="45"
                        Margin="0 10"
                        Click="TicketListing_Click"
                        Background="#334155"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="🗂 Ticket Records"
                        Height="45"
                        Margin="0 10"
                        Click="TicketRecords_Click"
                        Background="#334155"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="📅 Event Scheduler"
                        Height="45"
                        Margin="0 10"
                        Click="EventsScheduler_Click"
                        Background="#334155"
                        Foreground="White"
                        BorderThickness="0"/>       

                <Button Content="📨 Client Receiver"
                        Height="45"
                        Margin="0 10"
                        Click="ClientReceiver_Click"
                        Background="#334155"
                        Foreground="White"
                        BorderThickness="0"/>

            </StackPanel>

        </Border>

        <!-- ===================================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================================== -->

        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="#F4F6F9"/>

    </Grid>

</Window>