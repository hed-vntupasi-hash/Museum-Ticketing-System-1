<Page x:Class="SimpleAuthSystem.Pages.EventsSchedulerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F9">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="35.6"/>
            <RowDefinition Height="24.303"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <TextBlock Text="Event Scheduler"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#1E293B"
                   Margin="0,0,17,20" Grid.RowSpan="2"/>

        <!-- MAIN CARD -->

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="25" Margin="0,0,17,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- EVENT NAME -->

                    <TextBlock Text="Event Name"
                               FontWeight="SemiBold"
                               Margin="0 0 0 5"/>

                    <TextBox x:Name="txtEventName"
                             Height="35"
                             Margin="0 0 0 15"/>

                    <!-- DESCRIPTION -->

                    <TextBlock Text="Description"
                               FontWeight="SemiBold"
                               Margin="0 0 0 5"/>

                    <TextBox x:Name="txtDescription"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0 0 0 15"/>

                    <!-- START DATE -->

                    <TextBlock Text="Start Date"
                               FontWeight="SemiBold"
                               Margin="0 0 0 5"/>

                    <DatePicker x:Name="dpStartDate"
                                Height="35"
                                Margin="0 0 0 15"/>

                    <!-- END DATE -->

                    <TextBlock Text="End Date"
                               FontWeight="SemiBold"
                               Margin="0 0 0 5"/>

                    <DatePicker x:Name="dpEndDate"
                                Height="35"
                                Margin="0 0 0 20"/>

                    <!-- BUTTONS -->

                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 25">

                        <Button x:Name="btnBack"
                                Content="Back to Dashboard"
                                Click="btnBack_Click"
                                Width="150"
                                Height="35"
                                Margin="0,0,10,0"
                                Background="#334155"
                                Foreground="White"
                                BorderThickness="0"/>

                        <Button Content="Save Event"
                                Width="150"
                                Height="35"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Click="SaveEvent_Click"/>

                    </StackPanel>

                    <!-- EXISTING EVENTS TABLE -->

                    <TextBlock Text="Existing Events"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 10"
                               Foreground="#1E293B"/>

                    <DataGrid x:Name="dgEvents"
                              AutoGenerateColumns="False"
                              Height="300"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              BorderBrush="#D1D5DB"
                              BorderThickness="1">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="80"/>

                            <DataGridTextColumn Header="Event Name"
                                                Binding="{Binding Name}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Start Date"
                                                Binding="{Binding StartDate}"
                                                Width="150"/>

                            <DataGridTextColumn Header="End Date"
                                                Binding="{Binding EndDate}"
                                                Width="150"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</Page>