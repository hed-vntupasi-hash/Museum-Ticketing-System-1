<Window x:Class="SimpleAuthSystem.EventsScheduler"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Scheduler" Height="480" Width="420">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition/>
            <!-- RadioButtons -->
            <RowDefinition/>
            <!-- Label -->
            <RowDefinition/>
            <!-- Event Name -->
            <RowDefinition/>
            <!-- Start Date -->
            <RowDefinition/>
            <!-- End Date -->
            <RowDefinition Height="2*"/>
            <!-- Description -->
            <RowDefinition/>
            <!-- Save Button -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Choose RadioButtons -->
        <Label Content="Choose:" Grid.Row="0"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <RadioButton x:Name="rbShow" Content="Show" Margin="5" IsChecked="True"/>
            <RadioButton x:Name="rbHide" Content="Hide" Margin="5"/>
        </StackPanel>

        <!-- Label ComboBox -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <!-- Hide the label when Show is selected -->
                        <DataTrigger Binding="{Binding IsChecked, ElementName=rbShow}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <Label Content="Label:" Width="120"/>
            <ComboBox x:Name="cmbEventList" Width="200">
            </ComboBox>
        </StackPanel>

        <!-- Event Name (visible when Show is selected) -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=rbShow}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <Label Content="Event Name:" Width="120"/>
            <TextBox x:Name="txtEventName" Width="250" Margin="5"/>
        </StackPanel>

        <!-- Start Date -->
        <Label Content="Start Date:" Grid.Row="3"/>
        <DatePicker x:Name="dpStartDate" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <!-- End Date -->
        <Label Content="End Date:" Grid.Row="4"/>
        <DatePicker x:Name="dpEndDate" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <!-- Description -->
        <Label Content="Description:" Grid.Row="5"/>
        <TextBox x:Name="txtDescription"
                 Grid.Row="5"
                 Grid.Column="1"
                 Margin="5"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"/>

        <!-- Save Button -->
        <Button Content="Save Event"
                Grid.Row="7"
                Grid.ColumnSpan="2"
                Height="35"
                Click="SaveEvent_Click"/>

    </Grid>
</Window>