<Page x:Class="SimpleAuthSystem.Menulist"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Menulist"
      Background="#9FAFC1">

    <Page.Resources>

        <!-- LCD Palette -->
        <SolidColorBrush x:Key="LcdScreen" Color="#B8C4D6"/>
        <SolidColorBrush x:Key="LcdDark" Color="#3B3F73"/>
        <SolidColorBrush x:Key="LcdFrame" Color="#1F2450"/>
        <SolidColorBrush x:Key="LcdButton" Color="#D7DEE8"/>

        <!-- LCD Button Style -->
        <Style x:Key="LcdButtonStyle" TargetType="Button">

            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource LcdDark}"/>
            <Setter Property="Background" Value="{StaticResource LcdButton}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LcdFrame}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">

                            <Grid>

                                <!-- LCD Highlight -->
                                <Rectangle VerticalAlignment="Top"
                                           Height="6"
                                           Fill="#EEF3FA"
                                           Opacity="0.5"/>

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C8D3E0"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#98A6BA"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </Page.Resources>

    <Grid>

        <!-- Outer Device Frame -->
        <Border Width="370"
                Height="290"
                Background="#8FA0B5"
                BorderBrush="#1A1F4A"
                BorderThickness="8"
                CornerRadius="4"
                Padding="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <!-- LCD Screen -->
            <Border Background="{StaticResource LcdScreen}"
                    BorderBrush="{StaticResource LcdDark}"
                    BorderThickness="4"
                    Padding="15">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Text="SYSTEM MENU"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource LcdDark}"
                               FontFamily="Consolas"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <Button Content="QR READER"
                                Click="QrReader_Click"
                                Style="{StaticResource LcdButtonStyle}"/>

                        <Button Content="PURCHASE TICKET"
                                Click="PurchaseTicket_Click"
                                Style="{StaticResource LcdButtonStyle}"/>

                    </StackPanel>

                    <!-- Footer -->
                    <TextBlock Grid.Row="2"
                               Text="READY"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource LcdDark}"
                               FontFamily="Consolas"
                               HorizontalAlignment="Right"
                               Margin="0,15,4,0"/>

                </Grid>

            </Border>

        </Border>

    </Grid>

</Page>