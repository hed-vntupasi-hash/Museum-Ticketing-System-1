<Window x:Class="SimpleAuthSystem.Menulist"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SimpleAuthSystem"
        Title="Menulist" Height="600" Width="400">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <Button Content="QR Reader"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="QrReader_Click"/>

            <Button Content="QR Writer"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="QRWriter_Click"/>

            <Button Content="Purchase Ticket"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="PurchaseTicket_Click"/>

            <Button Content="Ticket Listing"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="TicketListing_Click"/>


            <Button Content="Ticket Records"
                    Width="120"
                    Height="40"
                    Margin="10"
                    Click="TicketRecords_Click"/>

            <Button Content="Event Scheduler"
                     Width="120"
                     Height="40"
                     Margin="10"
                    
                            Click="EventsScheduler_Click"/>

            <Button Content="Dashboard"
                    Width="120"
                    Height="40"
                    Margin="10"
                     Click="Dashboard_Click"/>
            <Button Content="Client Receiver"
                    Width="120"
                    Height="40"
                    Margin="10"
                     Click="ClientReceiver_Click"/>
        </StackPanel>
    </Grid>
</Window>