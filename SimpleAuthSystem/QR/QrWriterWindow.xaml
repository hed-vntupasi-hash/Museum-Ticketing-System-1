<Window x:Class="SimpleAuthSystem.QR.QrWriterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR Generator"
        Background="#9FAFC1"
        Width="420"
        Height="320">

    <Grid>

        <Border
            Width="420"
            Height="280"
            Background="#8FA0B5"
            BorderBrush="#1A1F4A"
            BorderThickness="8"
            CornerRadius="4"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="12">

            <Border
                Background="#B8C4D6"
                BorderBrush="#3B3F73"
                BorderThickness="4"
                Padding="15">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Text="QR GENERATOR"
                               FontSize="22"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               Foreground="#3B3F73"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Content -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Button Content="GENERATE QR"
                                Click="Generate_Click"
                                Width="200"
                                Height="50"
                                FontSize="16"
                                FontFamily="Consolas"
                                FontWeight="Bold"
                                Background="#D7DEE8"
                                BorderBrush="#1F2450"
                                BorderThickness="3"
                                Foreground="#3B3F73"
                                Margin="0,0,0,10"/>

                        <TextBlock Text="Numeric ID"
                                   FontFamily="Consolas"
                                   Foreground="#3B3F73"
                                   HorizontalAlignment="Center"/>

                        <TextBox Text="{Binding CurrentId}"
                                 IsReadOnly="True"
                                 Width="220"
                                 Margin="0,5,0,10"
                                 HorizontalContentAlignment="Center"/>

                        <TextBlock Text="Obfuscated Code"
                                   FontFamily="Consolas"
                                   Foreground="#3B3F73"
                                   HorizontalAlignment="Center"/>

                        <TextBox Text="{Binding GeneratedCode}"
                                 IsReadOnly="True"
                                 Width="220"
                                 Margin="0,5,0,10"
                                 HorizontalContentAlignment="Center"/>

                        <Image Source="{Binding QrCodeImage}"
                               Width="140"
                               Height="140"
                               HorizontalAlignment="Center"/>

                    </StackPanel>

                    <!-- Footer -->
                    <TextBlock Grid.Row="2"
                               Text="READY"
                               FontFamily="Consolas"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#3B3F73"
                               HorizontalAlignment="Right"/>

                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>