<Window x:Class="SimpleAuthSystem.QR.QrReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR Code Reader" Height="200" Width="400">
    <Grid>


        <StackPanel Margin="20">

            <Button Content="Select Image" HorizontalAlignment="Center" VerticalAlignment="Center" Width="120" Height="40" Click="Button_Click"/>

            <Separator Margin="0,20"/>

            <TextBlock Text="Server Response:" FontWeight="Bold"/>
            <TextBlock x:Name="ResponseLabel" Text="Waiting..." Margin="0,5" Foreground="DarkBlue"/>
            <TextBlock x:Name="StatusLabel" Text="Boolean: --" Foreground="DarkGreen"/>
        </StackPanel>

    </Grid>
</Window>