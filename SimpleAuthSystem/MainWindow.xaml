<Window x:Class="SimpleAuthSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Main Dashboard" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Welcome to the System!" FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="You have successfully logged in." Margin="0,10,0,20" HorizontalAlignment="Center"/>

            <Button Content="Logout" Click="btnLogout_Click" Width="100" Height="30" Background="#DC3545" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>