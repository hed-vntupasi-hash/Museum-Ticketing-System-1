<Window x:Class="SimpleAuthSystem.SignupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Account" Height="700" Width="450" WindowStartupLocation="CenterScreen">

    <Grid Background="#F0F0F0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Width="300" Margin="0,30">

                <TextBlock Text="Sign Up" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="First Name: *"/>
                <TextBox x:Name="txtFirstName" Margin="0,5,0,0" Padding="5"/>
                <TextBlock x:Name="errFirstName" Text="First name is required." Foreground="Red" FontSize="11" Margin="0,2,0,10" Visibility="Collapsed"/>

                <TextBlock Text="Last Name: *"/>
                <TextBox x:Name="txtLastName" Margin="0,5,0,0" Padding="5"/>
                <TextBlock x:Name="errLastName" Text="Last name is required." Foreground="Red" FontSize="11" Margin="0,2,0,10" Visibility="Collapsed"/>

                <TextBlock Text="Email:"/>
                <TextBox x:Name="txtEmail" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Phone:"/>
                <TextBox x:Name="txtPhone" Margin="0,5,0,15" Padding="5"/>

                <TextBlock Text="Username: *"/>
                <TextBox x:Name="txtUser" Margin="0,5,0,0" Padding="5"/>
                <TextBlock x:Name="errUser" Text="Username is required." Foreground="Red" FontSize="11" Margin="0,2,0,10" Visibility="Collapsed"/>

                <TextBlock Text="New Password: *"/>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="txtPass" Grid.Column="0" Padding="5" />
                    <TextBox x:Name="txtPassReveal" Grid.Column="0" Padding="5" Visibility="Collapsed" />
                    <ToggleButton x:Name="btnToggle" Grid.Column="1" Width="30" Content="👁" 
                                  Click="btnToggle_Click" Background="Transparent" BorderThickness="0"/>
                </Grid>
                <TextBlock x:Name="errPass" Text="Password is required." Foreground="Red" FontSize="11" Margin="0,2,0,20" Visibility="Collapsed"/>

                <Button Content="Register Now" Click="btnSignup_Click" Height="40" 
                        Background="#28A745" Foreground="White" FontWeight="Bold"/>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>